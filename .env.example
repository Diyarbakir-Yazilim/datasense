# ─── DataSense Ortam Değişkenleri ─────────────────────────────────
# Bu dosyayı .env olarak kopyalayın ve kendi API anahtarlarınızdan
# EN AZ BİRİNİ (OpenAI, Google veya Groq) doldurun.
# Sistem doldurduğunuz anahtara göre LLM modelini otomatik seçecektir.

# 1. OpenAI (ChatGPT)
OPENAI_API_KEY=your-openai-api-key-here

# 2. Google (Gemini)
GOOGLE_API_KEY=your-google-gemini-api-key-here

# 3. Groq (Llama3, Mixtral vb.)
GROQ_API_KEY=your-groq-api-key-here


# ─── Sistem Bağlantıları ─────────────────────────────────────────

# Redis Bağlantısı (Docker kullanılıyorsa varsayılan değerleri değiştirmeyin)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Backend Ayarları
DEBUG=True
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# AI API
AI_API_URL=http://ai_api:8001