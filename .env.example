# ─── DataSense Ortam Değişkenleri ─────────────────────────────────
# Bu dosyayı .env olarak kopyalayın ve değerleri ayarlayın.

# OpenAI API Anahtarı (Zorunlu)
OPENAI_API_KEY=your-api-key-here
# LLM Modeli
LLM_MODEL=

# Redis Bağlantısı
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Backend Ayarları
DEBUG=
UPLOAD_DIR=
MAX_FILE_SIZE_MB=

# AI API
AI_API_URL=
